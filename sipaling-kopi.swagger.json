  "components": {
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CategoryInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "Menu": {
          "type": "object",
          "properties": {
              "id": {
                  "type": "integer"
              },
              "name": {
                  "type": "string"
              },
              "category_id": {
                  "type": "integer"
              },
              "price": {
                  "type": "number",
                  "format": "decimal"
              },
              "is_available": {
                  "type": "boolean"
              },
              "stock": {
                  "type": "integer"
              }
          }
      },
      "MenuInput": {
          "type": "object",
          "properties": {
              "name": {
                  "type": "string"
              },
              "category_id": {
                  "type": "integer"
              },
              "price": {
                  "type": "number"
              },
              "is_available": {
                  "type": "boolean"
              },
              "stock": {
                  "type": "integer"
              }
          }
      },
      "Order": {
          "type": "object",
          "properties": {
              "id": {
                  "type": "integer"
              },
              "type": {
                  "type": "string",
                  "enum": ["dine_in", "takeaway"]
              },
              "table_no": {
                  "type": "integer",
                  "nullable": true
              },
              "status": {
                  "type": "string",
                  "enum": ["PENDING", "COMPLETED", "CANCELLED"]
              },
              "total_price": {
                  "type": "number",
                  "format": "decimal"
              }
          }
      },
      "OrderInput": {
          "type": "object",
          "properties": {
              "type": {
                  "type": "string",
                  "enum": ["dine_in", "takeaway"]
              },
              "table_no": {
                  "type": "integer",
                  "nullable": true
              },
              "status": {
                  "type": "string",
                  "enum": ["PENDING", "COMPLETED", "CANCELLED"]
              },
              "total_price": {
                  "type": "number"
              }
          }
      },
      "OrderItem": {
          "type": "object",
          "properties": {
              "id": {
                  "type": "integer"
              },
              "order_id": {
                  "type": "integer"
              },
              "menu_id": {
                  "type": "integer"
              },
              "quantity": {
                  "type": "integer"
              },
              "price": {
                  "type": "number",
                  "format": "decimal"
              },
              "status": {
                  "type": "string",
                  "enum": ["PENDING", "READY", "SERVED"]
              }
          }
      },
      "OrderItemInput": {
          "type": "object",
          "properties": {
              "order_id": {
                  "type": "integer"
              },
              "menu_id": {
                  "type": "integer"
              },
              "quantity": {
                  "type": "integer"
              },
              "price": {
                  "type": "number"
              },
              "status": {
                  "type": "string",
                  "enum": ["PENDING", "READY", "SERVED"]
              }
          }
      },
      "Payment": {
          "type": "object",
          "properties": {
              "id": {
                  "type": "integer"
              },
              "order_id": {
                  "type": "integer"
              },
              "payment_method": {
                  "type": "string",
                  "enum": ["cash", "credit_card"]
              },
              "status": {
                  "type": "string",
                  "enum": ["PENDING", "PAID", "FAILED"]
